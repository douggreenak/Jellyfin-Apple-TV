# ─── macOS ───────────────────────────────────────────────────────────────
.DS_Store
*.swp

# ─── Claude Code session files (machine-specific) ────────────────────────
.claude/

# ─── Node ────────────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Secrets / runtime data ──────────────────────────────────────────────
# .env holds the admin password + JWT secret; SQLite DBs hold Jellyfin
# credentials and per-device tokens. Never commit these.
.env
.env.local
.env.*.local
data/
data2/
*.db
*.db-shm
*.db-wal

# ─── Xcode ───────────────────────────────────────────────────────────────
DerivedData/
build/
*.xcuserstate
*.xcuserdatad
xcuserdata/
.swiftpm/
*.moved-aside
